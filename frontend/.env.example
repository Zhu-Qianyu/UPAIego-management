# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: device online/offline hysteresis (ms). ABSENT should exceed worst-case heartbeat interval.
# VITE_DEVICE_OFFLINE_RECENT_MS=15000
# VITE_DEVICE_OFFLINE_ABSENT_MS=90000

# Optional: map basemap tiles (Leaflet). Default is OpenStreetMap — no API key.
# If the map is blank/gray (often in mainland China), try Esri world street (still no key):
# VITE_MAP_TILE_URL=https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}
# VITE_MAP_TILE_ATTRIBUTION=Tiles &copy; Esri
