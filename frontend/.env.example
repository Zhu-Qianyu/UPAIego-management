# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: device online/offline hysteresis (ms). ABSENT should exceed worst-case heartbeat interval.
# VITE_DEVICE_OFFLINE_RECENT_MS=15000
# VITE_DEVICE_OFFLINE_ABSENT_MS=90000

# 数采地图：默认暂未上线；正式开放时设为 true 并配置下方高德 Key
# VITE_MAP_FEATURE_ENABLED=true
# 高德 JS API 2.0（https://lbs.amap.com → 应用管理 → Web 端 Key + 安全密钥）
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=
# 设备库中经纬度坐标系：wgs84（GPS，默认，展示时转 GCJ-02）或 gcj02
# VITE_MAP_COORD_SOURCE=wgs84
