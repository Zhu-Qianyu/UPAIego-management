# =============================================================================
# 生产环境使用【自建 CVM Supabase】，不是 Supabase 官方云！
# 详见仓库根目录 docs/自建Supabase服务器连接说明.md
# =============================================================================

# 自建 API（Kong 入口）。不要用 https://xxx.supabase.co
VITE_SUPABASE_URL=http://146.56.200.250:8000

# 从服务器 ~/supabase/docker/.env 复制 ANON_KEY（勿用云端项目的 anon key）
VITE_SUPABASE_ANON_KEY=your-self-hosted-anon-key-here

# 自建 Auth：服务器 .env 需 ENABLE_EMAIL_AUTOCONFIRM=true（见 scripts/server/fix_auth_email_autoconfirm.sh）

# Optional: device online/offline hysteresis (ms). ABSENT should exceed worst-case heartbeat interval.
# VITE_DEVICE_OFFLINE_RECENT_MS=15000
# VITE_DEVICE_OFFLINE_ABSENT_MS=90000

# 数采地图：默认在代码中 MAP_PAGE_LIVE=false（暂未上线页）
# VITE_MAP_FEATURE_ENABLED=true
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=
# VITE_MAP_COORD_SOURCE=wgs84

# 场景智能助手（默认豆包/火山方舟，见 docs/SCENE_AI_AGENT_SETUP.md）
# VITE_SCENE_AI_ENABLED=true
